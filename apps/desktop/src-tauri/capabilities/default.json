{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and any floating-* webview spawned via floating_window_create",
  "windows": [
    "main",
    "floating-*"
  ],
  "remote": {
    "urls": [
      "http://localhost",
      "http://localhost/*",
      "http://localhost:*",
      "http://localhost:*/*",
      "http://127.0.0.1",
      "http://127.0.0.1/*",
      "http://127.0.0.1:*",
      "http://127.0.0.1:*/*",
      "https://*.voquill.com",
      "https://*.voquill.com/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "log:default",
    "autostart:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        }
      ]
    },
    "updater:default",
    "process:default",
    "shell:allow-kill",
    "window-state:default",
    "shell:allow-stdin-write",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost"
        },
        {
          "url": "http://localhost/**"
        },
        {
          "url": "http://localhost:*"
        },
        {
          "url": "http://localhost:*/**"
        },
        {
          "url": "http://127.0.0.1"
        },
        {
          "url": "http://127.0.0.1/**"
        },
        {
          "url": "http://127.0.0.1:*"
        },
        {
          "url": "http://127.0.0.1:*/**"
        },
        {
          "url": "http://*:*"
        },
        {
          "url": "http://*:*/**"
        },
        {
          "url": "https://*"
        },
        {
          "url": "https://*/**"
        }
      ]
    }
  ]
}