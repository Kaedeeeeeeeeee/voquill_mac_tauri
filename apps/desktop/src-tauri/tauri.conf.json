{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voquill",
  "version": "0.1.0",
  "identifier": "com.voquill.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Voquill",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "additionalBrowserArgs": "--disable-features=CalculateNativeWinOcclusion --disable-renderer-backgrounding --disable-background-timer-throttling --disable-backgrounding-occluded-windows"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/transcription-audio/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "13.3",
      "entitlements": "macos/Voquill.entitlements",
      "signingIdentity": "Developer ID Application: SHIFENG ZHANG (Y4FV6WUU4V)"
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:voquill.db"
      ]
    },
    "updater": {
      "endpoints": [],
      "pubkey": "__UPDATER_PUBLIC_KEY__"
    }
  }
}